# ─────────────────────────────────────────────────────────────
#  Amazon Promo Bot – Variáveis de Ambiente

# ─────────────────────────────────────────────────────────────

# ── Banco de Dados ─────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=promodb
DB_USER=postgres
DB_PASSWORD=troque_essa_senha_123

# ── Amazon Associates (PA API v5) ──────────────────────────────
# Obtenha em: https://affiliate-program.amazon.com.br/assoc_credentials/home
AMAZON_ACCESS_KEY=SUA_ACCESS_KEY_AQUI
AMAZON_SECRET_KEY=SUA_SECRET_KEY_AQUI
AMAZON_PARTNER_TAG=seutag-20

# ── OpenAI ─────────────────────────────────────────────────────
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXX

# ── Telegram ───────────────────────────────────────────────────
# 1. Fale com @BotFather → /newbot → copie o token
# 2. Adicione o bot ao canal como admin
# 3. Para o chat_id do canal: use @nomecanal ou o ID numérico
TELEGRAM_BOT_TOKEN=1234567890:AAAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_BOT_USERNAME=SeuBotDePromos
TELEGRAM_CHAT_ID=@seucanaldepromocoes

# ── WhatsApp (Evolution API) ────────────────────────────────────
# A Evolution API sobe via Docker no mesmo compose
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=minha-chave-secreta
EVOLUTION_INSTANCE=minha-instancia

# IDs dos grupos do WhatsApp (separados por vírgula)
# Para descobrir o ID: GET /group/fetchAllGroups/{instance}
WHATSAPP_GRUPOS=120363000000000000@g.us
